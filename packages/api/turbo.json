{
  "$schema": "../../node_modules/turbo/schema.json",
  "extends": ["//"],

  "tasks": {
    "codegen": {
      "dependsOn": ["codegen:graphql"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!src/generated/**",
        "$TURBO_JIT$/src/generated/gql/*.ts"
      ]
    },
    "codegen:graphql": {
      "env": ["GITHUB_TOKEN"],
      "inputs": ["codegen.ts", "src/graphql/*/*.ts"],
      "outputs": ["src/generated/gql/*.ts"]
    }
  }
}
