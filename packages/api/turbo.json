{
  "$schema": "../../node_modules/turbo/schema.json",
  "extends": ["//"],

  "tasks": {
    "codegen": {
      "dependsOn": ["codegen:graphql"]
    },
    "codegen:graphql": {
      // Only needed to generate the schema, the specific token is not actually
      // relevant to the output
      "passThroughEnv": ["GITHUB_TOKEN"],
      "inputs": ["codegen.ts", "src/graphql/*/*.ts"],
      "outputs": ["src/generated/gql/*.ts"]
    }
  }
}
